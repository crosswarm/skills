      "inquiry_template": "您好，为帮您快速定位问题，请补充以下信息：\n{missing_fields_list}\n感谢配合！"
    },
    {
      "project": "流程中心",
      "issue_type_confirmed": "客开",
      "required": ["业务场景描述", "现行业务流说明", "期望实现效果"],
      "recommended": ["是否影响标准产品功能", "产品版本", "客户名称"],
      "optional": [],
