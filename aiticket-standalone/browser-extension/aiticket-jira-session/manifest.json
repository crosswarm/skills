{
  "manifest_version": 3,
  "name": "aiticket Jira 会话同步",
  "version": "0.1.0",
  "description": "自动抓取当前浏览器的 Jira JSESSIONID（httpOnly），推送到本地 aiticket 服务，免手动复制。",
  "permissions": ["cookies", "storage", "alarms"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "optional_host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "aiticket Jira 会话同步"
  }
}
